// Get display
let display = document.getElementById("display");

// Store current input
let current = "";

// Memory value
let memory = 0;

// Add numbers
function pressNum(num) {
  current += num;
  display.value = current;
}

// Add operators
function pressOp(op) {
  current += op;
  display.value = current;
}

// Clear everything
function clearAll() {
  current = "";
  display.value = "";
}

// Calculate result
function calculate() {
  try {
    current = eval(current).toString();
    display.value = current;
  } catch {
    display.value = "Error";
  }
}

// Memory functions
function memStore() {
  memory += Number(display.value || 0);
  updateMemoryDisplay();
}

function memRecall() {
  display.value = memory;
  current = memory.toString();
}

function memClear() {
  memory = 0;
  updateMemoryDisplay();
}

// Update memory text
function updateMemoryDisplay() {
  let memText = document.getElementById("mem-display");

  if (memory === 0) {
    memText.innerText = "Memory: empty";
  } else {
    memText.innerText = "Memory: " + memory;
  }
}

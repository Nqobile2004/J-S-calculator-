let currentInput = "0";
let storedValue = null;
let operator = null;
let justCalculated = false;
const history = [];
const memory = { value: 0, active: false };

function updateDisplay() {
  document.getElementById('screen').textContent = currentInput;
  document.getElementById('type-label').textContent = typeof parseFloat(currentInput);
}

function addHistoryItem(entry) {
  const li = document.createElement('li');
  li.textContent = entry;
  document.getElementById('history-list').prepend(li);
}

function pressNum(digit) {
  if (justCalculated) {
    currentInput = "0";
    justCalculated = false;
  }
  if (currentInput === "0") {
    currentInput = digit;
  } else {
    currentInput += digit;
  }
  updateDisplay();
}

function pressDot() {
  if (!currentInput.includes(".")) {
    currentInput += ".";
    updateDisplay();
  }
}

function setOp(op) {
  if (operator !== null && !justCalculated) calculate();
  storedValue = parseFloat(currentInput);
  operator = op;
  document.getElementById('history-line').textContent = storedValue + " " + operator;
  currentInput = "0";
  justCalculated = false;
  updateDisplay();
}

function calculate() {
  if (operator === null || storedValue === null) return;
  const current = parseFloat(currentInput);
  let result = 0;
  if (operator === '+') result = storedValue + current;
  if (operator === '-') result = storedValue - current;
  if (operator === '*') result = storedValue * current;
  if (operator === '/') result = storedValue / current;
  if (operator === '%') result = storedValue % current;
  const entry = storedValue + " " + operator + " " + current + " = " + result;
  history.push(entry);
  addHistoryItem(entry);
  document.getElementById('history-line').textContent = '';
  currentInput = String(result);
  operator = null;
  storedValue = null;
  justCalculated = true;
  updateDisplay();
}

function clearAll() {
  currentInput = "0";
  storedValue = null;
  operator = null;
  justCalculated = false;
  document.getElementById('history-line').textContent = '';
  updateDisplay();
}

function memStore() {
  memory.value = parseFloat(currentInput);
  memory.active = true;
  document.getElementById('mem-display').textContent = "Memory: " + memory.value;
}

function memRecall() {
  if (memory.active) {
    currentInput = String(memory.value);
    updateDisplay();
  }
}

function memClear() {
  memory.value = 0;
  memory.active = false;
  document.getElementById('mem-display').textContent = 'Memory: empty';
}

updateDisplay();
